# =============================================================================
# cardano-extract.env — Configuration for cardano key extraction script
# =============================================================================
# SECURITY: Restrict permissions on this file immediately after editing:
#   chmod 600 cardano-extract.env
#
# NEVER share this file or commit it to version control.
# ALWAYS run this on an offline / air-gapped machine.
# =============================================================================


# -----------------------------------------------------------------------------
# SEED PHRASE
# Your 24-word (or 15-word) mnemonic. Separate words with spaces.
# -----------------------------------------------------------------------------
SEED_PHRASE="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24"


# -----------------------------------------------------------------------------
# ACCOUNT INDEX
# The account you want to extract keys for.
# Maps to the account_index in path m/1852'/1815'/ACCOUNT_INDEX'/0/0
#
# Wallet UI label -> index:
#   Account 1 (default) -> 0
#   Account 2           -> 1
#   Account 3           -> 2
#   Account 4           -> 3
# -----------------------------------------------------------------------------
ACCOUNT_INDEX=0


# -----------------------------------------------------------------------------
# ADDRESS INDEX
# The address index within the account. Almost always 0 (first address).
# Only change this if you know you need a deeper address index.
# -----------------------------------------------------------------------------
ADDRESS_INDEX=0


# -----------------------------------------------------------------------------
# WALLET TYPE
# The era/purpose of your wallet. Options:
#   Shelley  — Daedalus, Yoroi, Lace, Eternl (most common, use this)
#   Byron    — Legacy Daedalus wallets only
# -----------------------------------------------------------------------------
WALLET_TYPE="Shelley"


# -----------------------------------------------------------------------------
# NETWORK
# mainnet or testnet
# -----------------------------------------------------------------------------
NETWORK="mainnet"


# -----------------------------------------------------------------------------
# VERIFICATION ADDRESS
# A known receive address from the target account in your wallet UI.
# The script will derive the address from the extracted key and compare.
# If they don't match, the script will abort and securely delete all temp files.
# Example: addr1qxy...
# -----------------------------------------------------------------------------
VERIFY_ADDRESS="addr1_PASTE_A_KNOWN_ADDRESS_FROM_YOUR_TARGET_ACCOUNT_HERE"


# -----------------------------------------------------------------------------
# OUTPUT DIRECTORY
# Where the final .skey and .vkey files will be saved.
# Ensure this directory exists and has appropriate permissions.
# Example: /home/user/cardano-keys  or  /media/usb-drive/keys
# -----------------------------------------------------------------------------
OUTPUT_DIR="$HOME/cardano-keys"


# -----------------------------------------------------------------------------
# BINARY PATHS
# Full paths to the cardano-address and cardano-cli binaries.
# Run `which cardano-address` and `which cardano-cli` to find them,
# or point directly to downloaded binaries.
# Examples:
#   /usr/local/bin/cardano-address
#   /home/user/cardano-tools/cardano-address
# -----------------------------------------------------------------------------
CARDANO_ADDRESS_BIN="/usr/local/bin/cardano-address"
CARDANO_CLI_BIN="/usr/local/bin/cardano-cli"


# -----------------------------------------------------------------------------
# SECURE DELETE COMMAND
# Command used to securely wipe temporary files.
# `shred` is standard on Ubuntu. Alternatives: `wipe`, `srm`
# -----------------------------------------------------------------------------
SHRED_BIN="/usr/bin/shred"
SHRED_OPTS="-u -z -n 3"   # 3 overwrite passes, then zero, then delete


# -----------------------------------------------------------------------------
# TEMP DIRECTORY
# Where intermediate key files are written during derivation.
# These are securely deleted after extraction. Use a non-tmpfs path
# if you want shred to be effective (tmpfs/ramdisk wipes on reboot anyway).
# Default: system tmp. Change to e.g. /home/user/cardano-tmp for ramdisk.
# -----------------------------------------------------------------------------
TEMP_DIR="/tmp/cardano_extract_$$"
